    "After dismissing the alarm, a confirmation request arrives after %lld min. No response for %lld min — the alarm rings again." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بعد إيقاف المنبه، يصلك طلب تأكيد بعد %lld د. بدون رد لمدة %lld د، يرن المنبه مجددًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach dem Ausschalten des Weckers erhältst du nach %lld Min. eine Bestätigungsanfrage. Keine Antwort für %lld Min. — der Wecker klingelt erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tras apagar la alarma, recibirás una solicitud de confirmación después de %lld min. Sin respuesta durante %lld min, la alarma vuelve a sonar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Après l'arrêt de l'alarme, une demande de confirmation arrive au bout de %lld min. Sans réponse pendant %lld min, l'alarme sonne à nouveau."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अलार्म बंद करने के बाद %lld मिनट में पुष्टि का अनुरोध आएगा। %lld मिनट तक जवाब न मिलने पर अलार्म फिर बजेगा।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アラームを止めると、%lld分後に確認通知が届きます。%lld分間応答がないと再び鳴ります。"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po wyłączeniu alarmu, po %lld min otrzymasz prośbę o potwierdzenie. Brak odpowiedzi przez %lld min — alarm zadzwoni ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Após desligar o alarme, você recebe um pedido de confirmação em %lld min. Sem resposta por %lld min, o alarme toca de novo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "После выключения будильника через %lld мин придёт запрос подтверждения. Нет ответа %lld мин — будильник зазвонит снова."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "关闭闹钟后，%lld 分钟后会收到确认请求。%lld 分钟内无响应，闹钟将再次响起。"
          }
        }
      }
    },
