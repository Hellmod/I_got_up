    "The alarm won't ring — enable alarms in Settings." : { "extractionState" : "manual", "localizations" : {
      "pl" : { "stringUnit" : { "state" : "translated", "value" : "Budzik nie zadzwoni — włącz alarmy w Ustawieniach." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Der Wecker klingelt nicht — aktiviere Wecker in den Einstellungen." } },
