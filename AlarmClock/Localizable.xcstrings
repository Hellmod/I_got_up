    "Confirm you're awake — otherwise the alarm will ring again." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أكّد أنك مستيقظ — وإلا سيرن المنبه مجددًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bestätige, dass du wach bist — sonst klingelt der Wecker erneut."
