    "To make alarms work, enable notifications for this app in Settings." : { "extractionState" : "manual", "localizations" : {
      "pl" : { "stringUnit" : { "state" : "translated", "value" : "Aby alarmy działały, włącz powiadomienia dla tej aplikacji w Ustawieniach." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Damit Wecker funktionieren, aktiviere Mitteilungen für diese App in den Einstellungen." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Para que las alarmas funcionen, activa las notificaciones de esta app en Ajustes." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Pour que les alarmes fonctionnent, activez les notifications de cette app dans Réglages." } },
      "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Para os alarmes funcionarem, ative as notificações deste app nos Ajustes." } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Чтобы будильники работали, включите уведомления для этого приложения в настройках." } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "アラームを使うには、設定でこのアプリの通知を有効にしてください。" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "要使闹钟正常工作，请在设置中为此应用开启通知。" } },
      "ar" : { "stringUnit" : { "state" : "translated", "value" : "لكي تعمل المنبهات، فعّل الإشعارات لهذا التطبيق في الإعدادات." } },
      "hi" : { "stringUnit" : { "state" : "translated", "value" : "अलार्म काम करें इसके लिए सेटिंग्स में इस ऐप की सूचनाएं चालू करें।" } }
